// ---------------------------------------------------------
// NEXUS ASSEMBLER - ARQUIVO DE CONFIGURAÇÃO GLOBAL
// ---------------------------------------------------------

manifest {
    name            = 'Nexus Assembler'
    author          = 'Nexus Core Team'
    description     = 'Pipeline de montagem híbrida e benchmarking de alta performance'
    mainScript      = 'main.nf'
    version         = '1.0.0'
}

process {
    cpus   = 2
    memory = '4 GB'
    time   = '2h'
    
    errorStrategy = { task.exitStatus in [143,137,104,134,139] ? 'retry' : 'finish' }
    maxRetries    = 2
}

profiles {
    
    local {
        process.executor = 'local'
    }

    hpc_slurm {
        process.executor = 'slurm'
        process.queue    = 'normal' 
        
        // --- STAGE 1 & 0: INFRAESTRUTURA DE BASE ---
        withName: 'FASTP_QC' {
            cpus   = 4
            memory = '8 GB'
            time   = '4h'
        }
        
        withName: 'GATEKEEPER' {
            cpus   = 1
            memory = '2 GB'
            time   = '10m'
        }

        withName: 'DORADO_BASECALL' {
            queue  = 'gpu'
            clusterOptions = '--gres=gpu:1'
            cpus   = 8
            memory = '32 GB'
            time   = '24h'
        }

        // --- STAGE 2: BENCHMARKING DE MONTADORES COMPARATIVOS ---
        withName: 'UNICYCLER_HYBRID' {
            cpus   = 16
            memory = '64 GB'
            time   = '48h'
        }

        withName: 'FLYE_LONG' {
            // O Flye usa muita memória para construir o grafo de repetição metagenômico
            cpus   = 16
            memory = '128 GB'
            time   = '24h'
        }

        withName: 'HIFIASM_LONG' {
            // Otimizado para leituras PacBio HiFi de alta fidelidade
            cpus   = 24
            memory = '128 GB'
            time   = '24h'
        }

        withName: 'CANU_LONG' {
            // O Canu possui alta precisão, mas exige muito tempo de processamento no HPC
            cpus   = 32
            memory = '256 GB'
            time   = '72h'
        }

        withName: 'VERKKO_HYBRID' {
            // Verkko combina leituras e exige bastante paralelismo para resolver o grafo
            cpus   = 32
            memory = '192 GB'
            time   = '48h'
        }

        // --- MOTOR NATIVO E CONSENSO ---
        withName: 'NEXUS_HYBRID_CORE' {
            cpus   = 16
            memory = '64 GB'
            time   = '24h'
        }

        withName: 'AUTOCYCLER_CONSENSUS' {
            cpus   = 8
            memory = '32 GB'
            time   = '12h'
        }
    }
}

def trace_timestamp = new java.util.Date().format( 'yyyy-MM-dd_HH-mm-ss')
timeline {
    enabled = true
    file    = "results/pipeline_info/execution_timeline_${trace_timestamp}.html"
}
report {
    enabled = true
    file    = "results/pipeline_info/execution_report_${trace_timestamp}.html"
}